NODE_ENV=development
HOST=0.0.0.0
PORT=8787

# Comma-separated extra origins for external integrations.
# Same-origin Render and custom-domain requests are detected automatically.
ALLOWED_ORIGINS=http://localhost:8787

# Use /var/data/website_data.sqlite on Render when the persistent disk is mounted.
SQLITE_DB_PATH=website_data.sqlite

# Required in production for the private submissions dashboard.
SUBMISSIONS_TOKEN=change-this-admin-token
SESSION_SECRET=change-this-long-random-session-secret
SESSION_COOKIE_NAME=heya_admin_session
SESSION_MAX_AGE_SECONDS=28800

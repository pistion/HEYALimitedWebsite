<%- include("partials/header", {
  active: "home",
  bodyId: "page-home",
  pageTitle: "CoreTalent PNG | HEYA Limited",
  pageDescription: "CoreTalent PNG by HEYA Limited connects PNG employers with qualified, job-ready talent across mining, oil & gas, construction, engineering, public sector, and security industries."
}) %>

<main id="content">
  <section class="hero section--dark">
    <canvas id="heroWireframeCanvas" class="wireframe-canvas" aria-hidden="true" hidden></canvas>
    <div class="container hero__grid">
      <div class="hero__content">
        <p class="eyebrow">CoreTalent PNG by HEYA Limited</p>
        <h1>PNG's Resource-Sector Talent Platform</h1>
        <p class="hero__lead">Connecting employers with qualified, job-ready talent across Papua New Guinea's mining, oil and gas, construction, engineering, public sector, and security industries.</p>
        <p class="hero__support">Powered by HEYA Limited and HY Strategic Talent Acquisition Partner, CoreTalent PNG helps businesses advertise roles, source candidates, screen applicants, and build reliable workforce pipelines.</p>
        <div class="button-row">
          <a class="btn btn--gold" href="/advertise"><i class="fa-solid fa-bullhorn" aria-hidden="true"></i>Advertise a Vacancy</a>
          <a class="btn btn--light" href="/contact"><i class="fa-solid fa-handshake" aria-hidden="true"></i>Request Recruitment Support</a>
        </div>
        <ul class="badge-row" aria-label="Industries served">
          <li>Mining Companies</li>
          <li>Oil &amp; Gas</li>
          <li>Construction &amp; Engineering</li>
          <li>Public Sector</li>
          <li>Private Security Firms</li>
        </ul>
      </div>

      <div class="hero__visual" aria-hidden="true"></div>
    </div>
  </section>

  <section class="section stats-strip" aria-label="CoreTalent PNG vision and mission">
    <p class="stats-note">Vision and mission.</p>
    <div class="container stat-grid vision-mission-grid">
      <article class="vision-mission-card">
        <p class="eyebrow">Vision</p>
        <h2>PNG's leading resource-sector talent platform</h2>
        <p>To become Papua New Guinea's leading resource-sector talent platform, connecting world-class employers with highly skilled local and international workforce.</p>
      </article>
      <article class="vision-mission-card">
        <p class="eyebrow">Mission</p>
        <h2>Reliable, strategic workforce solutions</h2>
        <p>To deliver efficient, reliable, and strategic workforce solutions through innovation, partnerships, and deep industry understanding.</p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container split">
      <div>
        <p class="eyebrow">What We Do</p>
        <h2>Built for Faster, Smarter Hiring in PNG</h2>
      </div>
      <p class="section-lead">CoreTalent PNG provides a focused recruitment and job advertising platform for employers that need reliable access to qualified candidates in high-demand industries.</p>
    </div>
    <div class="container card-grid card-grid--four">
      <article class="card">
        <span class="card__kicker">01</span>
        <h3>Job Advertising</h3>
        <p>Promote vacancies through structured listings and targeted visibility.</p>
      </article>
      <article class="card">
        <span class="card__kicker">02</span>
        <h3>Talent Sourcing</h3>
        <p>Connect with suitable candidates for technical, operational, and project roles.</p>
      </article>
      <article class="card">
        <span class="card__kicker">03</span>
        <h3>Candidate Screening</h3>
        <p>Reduce weak applications with resume review, shortlisting, and role matching.</p>
      </article>
      <article class="card">
        <span class="card__kicker">04</span>
        <h3>Workforce Mobilization</h3>
        <p>Support workforce planning and project ramp-up requirements across PNG.</p>
      </article>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Industries</p>
        <h2>Industries We Serve</h2>
        <p>CoreTalent PNG is designed for workforce-heavy sectors where reliable talent, speed, and industry understanding matter.</p>
      </div>
      <ul class="industry-list" aria-label="Industries served">
        <li>Mining Companies</li>
        <li>Oil &amp; Gas</li>
        <li>Construction &amp; Engineering</li>
        <li>Public Sector</li>
        <li>Private Security Firms</li>
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="container section-heading">
      <p class="eyebrow">Services</p>
      <h2>Recruitment Solutions Designed for PNG's Workforce Needs</h2>
      <p>Support for employers moving from vacancy advertising through candidate reach, screening, and practical workforce readiness.</p>
    </div>
    <div class="container card-grid">
      <article class="card">
        <h3>Job Advertising Platform</h3>
        <ul class="check-list">
          <li>High-visibility listings</li>
          <li>Industry-targeted promotion</li>
          <li>Featured advertisement options</li>
        </ul>
      </article>
      <article class="card">
        <h3>Talent Sourcing & Screening</h3>
        <ul class="check-list">
          <li>Candidate matching</li>
          <li>Resume screening</li>
          <li>Employer-ready shortlists</li>
        </ul>
      </article>
      <article class="card">
        <h3>Workforce Mobilization Support</h3>
        <ul class="check-list">
          <li>FIFO workforce coordination</li>
          <li>Deployment readiness</li>
          <li>Project ramp-up support</li>
        </ul>
      </article>
      <article class="card">
        <h3>Recruitment Partnership</h3>
        <ul class="check-list">
          <li>End-to-end recruitment support</li>
          <li>Strategic hiring advisory</li>
          <li>Bulk recruitment planning</li>
        </ul>
      </article>
    </div>
    <div class="container section-action">
      <a class="btn btn--outline" href="/services">View All Services</a>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container split">
      <div>
        <p class="eyebrow">Why Choose Us</p>
        <h2>Why Employers Choose CoreTalent PNG</h2>
      </div>
      <ol class="reason-line" aria-label="Reasons employers choose CoreTalent PNG">
        <li>
          <span>
            <strong>Resource-Sector Focus</strong>
            <em>Built around PNG's mining, oil and gas, construction, engineering, public-sector, and security workforce needs.</em>
          </span>
        </li>
        <li>
          <span>
            <strong>Experienced Recruitment Leadership</strong>
            <em>Backed by founder experience across major workforce and recruitment environments in Papua New Guinea.</em>
          </span>
        </li>
        <li>
          <span>
            <strong>Faster Hiring Support</strong>
            <em>Designed to reduce delays in candidate sourcing, screening, shortlisting, and mobilization.</em>
          </span>
        </li>
        <li>
          <span>
            <strong>Local Market Understanding</strong>
            <em>Focused on PNG employers, PNG candidates, and practical workforce realities.</em>
          </span>
        </li>
        <li>
          <span>
            <strong>Employer Visibility</strong>
            <em>Vacancies and employer brands can be promoted through digital and social media channels.</em>
          </span>
        </li>
      </ol>
    </div>
  </section>

  <section class="section packages-preview section--dark">
    <div class="container split split--center">
      <div>
        <p class="eyebrow eyebrow--gold">Packages</p>
        <h2>Employer Packages Built Around Hiring Outcomes</h2>
        <p>Choose the level of visibility and recruitment support that matches your vacancy urgency, hiring volume, and workforce goals.</p>
      </div>
      <a class="btn btn--gold" href="/packages">Explore Package Options</a>
    </div>
    <div class="container pricing-grid pricing-grid--preview">
      <article class="price-card package-preview-card">
        <span class="package-label">Listing Visibility</span>
        <h3>Silver Package</h3>
        <p>For employers who need a professional vacancy presence and a clear pathway for interested candidates.</p>
        <ul class="package-feature-list">
          <li>Structured vacancy placement</li>
          <li>Standard employer enquiry support</li>
          <li>Suitable for single-role visibility</li>
        </ul>
        <p class="package-fit">Best for straightforward vacancy advertising.</p>
      </article>
      <article class="price-card package-preview-card">
        <span class="package-label">Priority Reach</span>
        <h3>Bronze Package</h3>
        <p>For teams managing recurring vacancies or needing stronger visibility across priority candidate segments.</p>
        <ul class="package-feature-list">
          <li>Multiple vacancy posting support</li>
          <li>Featured listing placement</li>
          <li>Candidate pipeline visibility</li>
        </ul>
        <p class="package-fit">Best for active hiring cycles.</p>
      </article>
      <article class="price-card package-preview-card price-card--featured">
        <span class="pill">Premium / Recommended</span>
        <span class="package-label">Strategic Partnership</span>
        <h3>Gold Package</h3>
        <p>For employers who need deeper recruitment support, stronger market reach, and a more hands-on workforce pipeline.</p>
        <ul class="package-feature-list">
          <li>Premium vacancy visibility</li>
          <li>Dedicated recruitment support</li>
          <li>Candidate sourcing and screening focus</li>
        </ul>
        <p class="package-fit">Best for critical or high-volume workforce needs.</p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container feature-band">
      <div>
        <p class="eyebrow">Founder Credibility</p>
        <h2>Founded by Hekeria Yako</h2>
        <p>With over 20 years of experience in workforce management and recruitment within Papua New Guinea's resource sector, Hekeria Yako brings practical recruitment leadership, workforce mobilization experience, and a strong industry network across PNG.</p>
        <a class="text-link" href="/about">Learn About HEYA Limited</a>
      </div>
      <ol class="achievement-line" aria-label="Founder credibility highlights">
        <li><span>20+ years workforce experience</span></li>
        <li><span>Major mining recruitment exposure</span></li>
        <li><span>Large-scale recruitment campaign experience</span></li>
        <li><span>Strong PNG HR and recruitment network</span></li>
      </ol>
    </div>
  </section>

  <section class="section cta-band">
    <div class="container cta-band__inner">
      <h2>Ready to advertise a vacancy or build your workforce pipeline?</h2>
      <p>Partner with CoreTalent PNG to reach qualified candidates, improve vacancy visibility, and access recruitment support built around PNG's workforce needs.</p>
      <div class="button-row button-row--center">
        <a class="btn btn--gold" href="/advertise">Advertise a Vacancy</a>
        <a class="btn btn--dark" href="/contact">Contact HEYA Limited</a>
      </div>
    </div>
  </section>
</main>

<%- include("partials/footer") %>

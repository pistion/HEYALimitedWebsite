<%- include("partials/header", {
  active: "services",
  bodyId: "page-services",
  pageTitle: "Services | CoreTalent PNG",
  pageDescription: "Employer-focused job advertising, candidate screening, mobilization, recruitment partnership, labour hire support, and promotion services."
}) %>

<main id="content">
  <section class="page-hero section--dark">
    <canvas id="servicesWireframeCanvas" class="wireframe-canvas" aria-hidden="true" hidden></canvas>
    <div class="container page-hero__inner">
      <p class="eyebrow eyebrow--gold">Services</p>
      <h1>Recruitment & Workforce Solutions</h1>
      <p>Practical job advertising, talent sourcing, screening, and workforce support for employers across Papua New Guinea's high-demand industries.</p>
      <div class="button-row">
        <a class="btn btn--gold" href="/advertise"><i class="fa-solid fa-bullhorn" aria-hidden="true"></i>Advertise a Vacancy</a>
        <a class="btn btn--light" href="/contact"><i class="fa-solid fa-handshake" aria-hidden="true"></i>Contact Recruitment Partner</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <p class="eyebrow">Recruitment Journey</p>
      <h2>From Vacancy Advertising to Workforce Mobilization</h2>
      <p>CoreTalent PNG supports employers through the full recruitment journey: promoting vacancies, reaching targeted candidates, screening applications, shortlisting talent, and supporting workforce readiness for project and operational needs.</p>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container card-grid">
      <article class="card">
        <span class="icon-badge">01</span>
        <h3>Job Advertising Platform</h3>
        <p>High-visibility vacancy advertising for employers that need targeted candidate reach.</p>
        <ul class="check-list">
          <li>Job posting access</li>
          <li>Featured listing options</li>
          <li>High-priority advertisements</li>
          <li>LinkedIn and Facebook promotion support</li>
        </ul>
      </article>
      <article class="card">
        <span class="icon-badge">02</span>
        <h3>Talent Sourcing & Screening</h3>
        <p>Support for identifying candidates who match employer requirements.</p>
        <ul class="check-list">
          <li>Pre-qualified candidate access</li>
          <li>Resume screening</li>
          <li>Candidate shortlisting</li>
          <li>Skills and experience matching</li>
        </ul>
      </article>
      <article class="card">
        <span class="icon-badge">03</span>
        <h3>Workforce Mobilization Support</h3>
        <p>Support for employers preparing candidates for site, FIFO, project, or operational deployment.</p>
        <ul class="check-list">
          <li>FIFO workforce coordination</li>
          <li>Deployment readiness</li>
          <li>Job-ready candidate pipeline</li>
          <li>Project workforce support</li>
        </ul>
      </article>
      <article class="card">
        <span class="icon-badge">04</span>
        <h3>Recruitment Partnership</h3>
        <p>Strategic recruitment support for companies that need more than basic job advertising.</p>
        <ul class="check-list">
          <li>End-to-end recruitment support</li>
          <li>Strategic hiring advisory</li>
          <li>Bulk recruitment</li>
          <li>Project recruitment</li>
          <li>Client partnership support</li>
        </ul>
      </article>
      <article class="card">
        <span class="icon-badge">05</span>
        <h3>Labour Hire Support</h3>
        <p>Workforce support for employers needing practical labour solutions and candidate coordination.</p>
        <ul class="check-list">
          <li>Workforce pipeline support</li>
          <li>Job-ready labour coordination</li>
          <li>Project labour support</li>
          <li>Candidate availability support</li>
        </ul>
      </article>
      <article class="card">
        <span class="icon-badge">06</span>
        <h3>Employer Branding</h3>
        <p>Visibility support for employers that want to stand out to candidates.</p>
        <ul class="check-list">
          <li>Featured listings</li>
          <li>Employer spotlight</li>
          <li>Social media campaign support</li>
          <li>Recruitment visibility</li>
        </ul>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container section-heading section-heading--center">
      <p class="eyebrow">How it works</p>
      <h2>How the Employer Process Works</h2>
    </div>

    <div class="container process-grid process-grid--five">
      <article class="process-card">
        <span>01</span>
        <h3>Submit Your Hiring Need</h3>
        <p>Tell CoreTalent PNG what role, industry, location, and workforce support you need.</p>
      </article>
      <article class="process-card">
        <span>02</span>
        <h3>Choose Advertising or Recruitment Support</h3>
        <p>Select a package or request a custom recruitment partnership.</p>
      </article>
      <article class="process-card">
        <span>03</span>
        <h3>Reach Targeted Candidates</h3>
        <p>Vacancies are prepared for visibility across relevant candidate and industry audiences.</p>
      </article>
      <article class="process-card">
        <span>04</span>
        <h3>Screen and Shortlist Talent</h3>
        <p>Candidates can be reviewed, screened, and matched based on employer requirements.</p>
      </article>
      <article class="process-card">
        <span>05</span>
        <h3>Build Your Workforce Pipeline</h3>
        <p>Employers receive practical support for hiring, mobilization, or ongoing recruitment needs.</p>
      </article>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container section-heading section-heading--center">
      <p class="eyebrow">Industries Supported</p>
      <h2>Focused on PNG's workforce-heavy sectors</h2>
    </div>
    <div class="container industry-grid industry-grid--compact">
      <span>Mining</span>
      <span>Oil & Gas</span>
      <span>Construction</span>
      <span>Engineering</span>
      <span>Public Sector</span>
      <span>Private Security</span>
      <span>FIFO Workforce</span>
      <span>Project Recruitment</span>
    </div>
  </section>

  <section class="section cta-band">
    <div class="container cta-band__inner">
      <h2>Need candidates, vacancy advertising, or recruitment support?</h2>
      <div class="button-row button-row--center">
        <a class="btn btn--gold" href="/advertise"><i class="fa-solid fa-bullhorn" aria-hidden="true"></i>Advertise a Vacancy</a>
        <a class="btn btn--dark" href="/packages"><i class="fa-solid fa-layer-group" aria-hidden="true"></i>View Packages</a>
      </div>
    </div>
  </section>
</main>

<%- include("partials/footer") %>

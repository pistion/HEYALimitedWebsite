<%- include("partials/header", {
  active: "about",
  bodyId: "page-about",
  pageTitle: "About | CoreTalent PNG",
  pageDescription: "Learn about CoreTalent PNG, HEYA Limited, and HY Strategic Talent Acquisition Partner."
}) %>

<main id="content">
  <section class="page-hero section--dark">
    <canvas id="aboutWireframeCanvas" class="wireframe-canvas" aria-hidden="true" hidden></canvas>
    <div class="container page-hero__inner">
      <p class="eyebrow eyebrow--gold">About</p>
      <h1>About CoreTalent PNG</h1>
      <p>A PNG-focused job advertising and workforce solutions platform operated by HEYA Limited and powered by HY Strategic Talent Acquisition Partner.</p>
    </div>
  </section>

  <section class="section">
    <div class="container section-heading">
      <p class="eyebrow">Brand Structure</p>
      <h2>One Platform. Clear Workforce Purpose.</h2>
    </div>
    <div class="container card-grid">
      <article class="card">
        <h3>CoreTalent PNG</h3>
        <p>The public-facing job advertising and workforce solutions platform.</p>
      </article>
      <article class="card">
        <h3>HEYA Limited</h3>
        <p>The registered company behind the platform.</p>
      </article>
      <article class="card">
        <h3>HY Strategic Talent Acquisition Partner</h3>
        <p>The specialized recruitment and workforce solutions division.</p>
      </article>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container feature-band feature-band--light">
      <div>
        <p class="eyebrow">CoreTalent PNG</p>
        <h2>Built for PNG's High-Demand Workforce Sectors</h2>
        <p>CoreTalent PNG is designed to connect employers with qualified, job-ready talent across Papua New Guinea's mining, oil and gas, construction, engineering, public-sector, security, and FIFO workforce markets.</p>
      </div>
      <ul class="check-list check-list--large">
        <li>Targeted job advertising</li>
        <li>Candidate sourcing and screening</li>
        <li>Workforce pipeline support</li>
        <li>Recruitment partnership services</li>
        <li>Employer visibility and social media promotion</li>
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="container section-heading">
      <p class="eyebrow">Company Backing</p>
      <h2>Backed by HEYA Limited</h2>
      <p>HEYA Limited operates as a workforce solutions provider through HY Strategic Talent Acquisition Partner, supporting talent acquisition strategy, recruitment operations, workforce mobilization, and client partnerships.</p>
    </div>
    <div class="container card-grid two-col">
      <article class="card">
        <h3>HEYA Limited</h3>
        <p>Registered PNG company focused on workforce solutions.</p>
      </article>
      <article class="card">
        <h3>HY STAP</h3>
        <p>Specialized division focused on talent acquisition, recruitment operations, workforce mobilization, and recruitment partnerships.</p>
      </article>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container feature-band">
      <div>
        <p class="eyebrow">Founder Story</p>
        <h2>Founded by Hekeria Yako</h2>
        <p>Founded by Hekeria Yako, HEYA Limited was created to connect Papua New Guineans with real employment opportunities while supporting businesses with practical recruitment and workforce solutions.</p>
      </div>
      <div class="quote-panel">
        <strong>Built on 20+ years of strategic talent acquisition experience in Papua New Guinea's resource sector.</strong>
      </div>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container card-grid two-col">
      <article class="mission-card">
        <p class="eyebrow eyebrow--gold">Vision</p>
        <h2>PNG's leading resource-sector talent platform</h2>
        <p>To become Papua New Guinea's leading resource-sector talent platform, connecting world-class employers with highly skilled local and international workforce.</p>
      </article>
      <article class="mission-card">
        <p class="eyebrow eyebrow--gold">Mission</p>
        <h2>Reliable, strategic workforce solutions</h2>
        <p>To deliver efficient, reliable, and strategic workforce solutions through innovation, partnerships, and deep industry understanding.</p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container split">
      <div>
        <p class="eyebrow">Founder Track Record</p>
        <h2>Founder Track Record</h2>
      </div>
      <p class="section-lead">Hekeria Yako brings more than 20 years of experience in workforce management and recruitment within Papua New Guinea's resource sector. These points are founder career highlights, not unverified company achievements.</p>
    </div>
    <div class="container track-record-sheet">
      <article>
        <h3>20+ Years Industry Experience</h3>
        <p>Recruitment, workforce planning, and HR operations in major resource-sector environments.</p>
      </article>
      <article>
        <h3>Large-Scale Workforce Transition</h3>
        <p>Experience supporting major redundancy and workforce transition exercises with professionalism and structure.</p>
      </article>
      <article>
        <h3>Porgera Mine Restart Recruitment Campaign</h3>
        <p>Experience contributing to a major recruitment drive involving more than 2,500 employees within 6 months.</p>
      </article>
      <article>
        <h3>Recruitment Efficiency Improvement</h3>
        <p>Experience improving recruitment turnaround from long-cycle hiring toward faster, more practical hiring timelines.</p>
      </article>
      <article>
        <h3>Gender Diversity Leadership</h3>
        <p>Experience supporting workforce inclusion and improved female participation in mining workforce environments.</p>
      </article>
      <article>
        <h3>Strong PNG Industry Network</h3>
        <p>Connected across recruiters, HR professionals, employers, and resource-sector stakeholders in Papua New Guinea.</p>
      </article>
    </div>
  </section>

  <section class="section cta-band">
    <div class="container cta-band__inner">
      <h2>Looking for a recruitment partner with PNG resource-sector understanding?</h2>
      <div class="button-row button-row--center">
        <a class="btn btn--gold" href="/contact">Request Recruitment Support</a>
        <a class="btn btn--dark" href="/services">View Services</a>
      </div>
    </div>
  </section>
</main>

<%- include("partials/footer") %>
